# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (For strict CORS policy)
# Local: http://localhost:5173
# Production: https://creator-flow-livid.vercel.app
CLIENT_URL=http://localhost:5173

# Database
# Your MongoDB connection string (e.g., MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/creatorflow

# Authentication
# Secret keys for signing JSON Web Tokens securely
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# External APIs
# Google Gemini API key for AI generation features
GEMINI_API_KEY=your_google_gemini_api_key
